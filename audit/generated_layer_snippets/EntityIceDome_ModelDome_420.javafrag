        PartPose.offsetAndRotation(7.0F, 0.0F, 3.0F, -0.7854F, -0.7854F, 0.0F)
    );

    PartDefinition bone18 = roof.addOrReplaceChild(
        "bone18",
        CubeListBuilder.create()
            .texOffs(0, 8)
            .addBox(-4.0F, -2.3431F, -5.6569F, 8.0F, 8.0F, 0.0F, new CubeDeformation(0.0F)),
        PartPose.offsetAndRotation(0.0F, 0.0F, 19.2F, 0.7854F, 0.0F, 0.0F)
    );

    PartDefinition bone16 = roof.addOrReplaceChild(
        "bone16",
        CubeListBuilder.create()
            .texOffs(0, 8)
            .addBox(-4.2426F, -2.3431F, -5.6569F, 8.0F, 8.0F, 0.0F, new CubeDeformation(0.0F)),
        PartPose.offsetAndRotation(7.0F, 0.0F, 16.3F, 0.7854F, 0.7854F, 0.0F)
    );

    PartDefinition bone14 = roof.addOrReplaceChild(
        "bone14",
        CubeListBuilder.create()
            .texOffs(0, 8)
            .addBox(-4.1F, -2.3431F, 5.7569F, 8.0F, 8.0F, 0.0F, new CubeDeformation(0.0F)),
        PartPose.offsetAndRotation(9.75F, 0.0F, 9.75F, -0.7854F, -1.5708F, 0.0F)
    );

    PartDefinition bone17 = roof.addOrReplaceChild(
        "bone17",
        CubeListBuilder.create()
            .texOffs(0, 8)
            .mirror()
            .addBox(-3.9F, -2.3431F, 5.7569F, 8.0F, 8.0F, 0.0F, new CubeDeformation(0.0F))
            .mirror(false),
        PartPose.offsetAndRotation(-9.65F, 0.0F, 9.75F, -0.7854F, 1.5708F, 0.0F)
