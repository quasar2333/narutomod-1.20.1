    PartDefinition cube_r3 = roof.addOrReplaceChild(
        "cube_r3",
        CubeListBuilder.create()
            .texOffs(0, 8)
            .addBox(-4.0609F, -8.0F, 0.0457F, 8.0F, 8.0F, 0.0F, new CubeDeformation(0.0F)),
        PartPose.offsetAndRotation(-6.8F, 8.0F, 2.7F, -0.7854F, 0.7854F, 0.0F)
    );

    PartDefinition cube_r4 = roof.addOrReplaceChild(
        "cube_r4",
        CubeListBuilder.create()
            .texOffs(0, 8)
            .addBox(-3.8609F, -7.9F, -0.0457F, 8.0F, 8.0F, 0.0F, new CubeDeformation(0.0F)),
        PartPose.offsetAndRotation(-6.8F, 8.0F, 16.3F, 0.7854F, -0.7854F, 0.0F)
    );

    return LayerDefinition.create(mesh, 16, 16);
